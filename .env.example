# Copy to .env.local for local dev. On Vercel: Project → Settings → Environment Variables
# (enable for Production and redeploy after changes).

# --- Demo lead API (/api/demo-lead): need at least one of Resend OR webhook ---
# Option A — Resend (both required if using email send)
RESEND_API_KEY=
# Verified sender, e.g. Agent Vocal <noreply@yourdomain.com>
DEMO_EMAIL_FROM=

# Option B — Webhook (JSON POST body = full payload: form, clientSession, server)
# e.g. Zapier/Make Catch Hook → email
DEMO_LEAD_WEBHOOK_URL=

# Optional — override notification inbox (default in code: francis@hellodarwin.com)
# DEMO_LEAD_TO=

# --- Retell private demo page (/demo-prive) ---
# Create a Voice Agent in Retell, then copy the API key + agent id here.
RETELL_API_KEY=
RETELL_AGENT_ID=
# Optional: pin a specific published agent version for tomorrow's demo
# RETELL_AGENT_VERSION=

# Troubleshooting (Vercel → Deployment → Logs):
# HTTP 503 = neither Resend (both vars) nor DEMO_LEAD_WEBHOOK_URL set for this environment.
# HTTP 502 = Resend and/or webhook returned an error; look for "Resend error" or "DEMO_LEAD_WEBHOOK_URL error".
